# Pyhron .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
sdist/
wheels/

# Virtual environments
.venv/
venv/
ENV/

# IDE & Editors
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# Testing
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
playwright-report/
test-results/

# Linting & Type Checking
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# Environment & Secrets
.env
.env.local
.env.*.local
*.pem
*.key

# ML & Experiments
mlruns/
mlartifacts/
*.onnx
*.pt
*.pth
*.pkl
*.joblib

# Databases
*.db
*.sqlite3

# Docker
docker-compose.override.yml

# OS generated files
.DS_Store
Thumbs.db
Desktop.ini

# Node (if any frontend tooling)
node_modules/
package-lock.json
yarn.lock

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
logs/

# Misc
*.bak
*.tmp
.cache/
secrets/
