# =============================================================================
# Enthropy Trading Platform — Environment Configuration
# =============================================================================
# Copy to .env:  cp .env.example .env
# NEVER commit .env to version control.
# =============================================================================

# -- General -----------------------------------------------------------------

# Deployment environment: development | staging | production | testing
ENVIRONMENT=development

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# -- Database (TimescaleDB / PostgreSQL) -------------------------------------

# Used by docker-compose to initialise the database
POSTGRES_USER=enthropy
POSTGRES_PASSWORD=enthropy_dev
POSTGRES_DB=enthropy
POSTGRES_PORT=5432

# SQLAlchemy async connection URL (auto-configured by docker-compose)
DATABASE_URL=postgresql+asyncpg://enthropy:enthropy_dev@localhost:5432/enthropy

# -- Redis -------------------------------------------------------------------

REDIS_PASSWORD=enthropy_dev
REDIS_PORT=6379

# Full Redis URL (auto-configured by docker-compose)
REDIS_URL=redis://:enthropy_dev@localhost:6379/0

# -- Kafka -------------------------------------------------------------------

# Broker address (inside docker network: kafka:29092, from host: localhost:9092)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_PORT=9092

# -- Authentication & Security -----------------------------------------------

# Application secret (generate: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=local-dev-secret-key-change-in-production

# JWT signing secret (min 16 chars, generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=local-dev-jwt-secret-change-in-prod

# Fernet encryption key (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me-to-a-fernet-key

# -- Market Data & Brokerage (optional for local dev) -----------------------

# Polygon.io API key
POLYGON_API_KEY=

# Alpaca paper trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# IDX API key (Indonesian exchange)
IDX_API_KEY=

# CCXT crypto exchange name (binance, coinbase, kraken)
CCXT_EXCHANGE=binance

# -- ML & Experiment Tracking ------------------------------------------------

MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_PORT=5000

# -- Monitoring (optional, enable with --profile monitoring) -----------------

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=enthropy_grafana
GRAFANA_ROOT_URL=http://localhost:3000

# -- API Gateway -------------------------------------------------------------

API_PORT=8000
IMAGE_TAG=latest
