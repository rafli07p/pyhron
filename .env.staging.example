# Load with:  docker compose --env-file .env.staging -f ... up -d

# Application
APP_ENV=staging
APP_SECRET_KEY=REPLACE-with-min-32-char-random-string
APP_PORT=8000

# Database (PostgreSQL 16 + TimescaleDB)
POSTGRES_USER=pyhron_staging
POSTGRES_PASSWORD=REPLACE-with-strong-password
POSTGRES_DB=pyhron_staging

# Redis
REDIS_PASSWORD=REPLACE-with-strong-password

# Authentication
JWT_SECRET_KEY=REPLACE-with-min-64-char-random-string-for-staging
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Alpaca Paper Trading
ALPACA_API_KEY=REPLACE-with-alpaca-paper-api-key
ALPACA_SECRET_KEY=REPLACE-with-alpaca-paper-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Paper Trading Defaults
PAPER_TRADING_SYMBOLS=AAPL MSFT GOOGL AMZN TSLA
PAPER_TRADING_CAPITAL=500000000

# Market Data
EODHD_API_KEY=REPLACE-with-eodhd-api-key

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Monitoring
LOG_LEVEL=INFO
GRAFANA_ADMIN_PASSWORD=REPLACE-with-grafana-password
SENTRY_DSN=