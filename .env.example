# Pyhron — Environment Configuration
# Copy to .env:  cp .env.example .env
# NEVER commit .env to version control.

# Application
APP_ENV=development
APP_SECRET_KEY=REPLACE-with-min-32-char-random-string
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (PostgreSQL 16 + TimescaleDB)
DATABASE_URL=postgresql+asyncpg://pyhron:pyhron@localhost:5432/pyhron
DATABASE_SYNC_URL=postgresql+psycopg://pyhron:pyhron@localhost:5432/pyhron
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

POSTGRES_USER=pyhron
POSTGRES_PASSWORD=pyhron
POSTGRES_DB=pyhron

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=pyhron-consumers

# Market Data — IDX Primary
EODHD_API_KEY=REPLACE-with-eodhd-api-key

# Market Data — Global / Fallback
POLYGON_API_KEY=REPLACE-with-polygon-api-key
ALPACA_API_KEY=REPLACE-with-alpaca-api-key
ALPACA_SECRET_KEY=REPLACE-with-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Authentication
JWT_SECRET_KEY=REPLACE-with-min-64-char-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Risk Engine
RISK_MAX_POSITION_SIZE_PCT=0.10
RISK_MAX_SECTOR_CONCENTRATION_PCT=0.30
RISK_DAILY_LOSS_LIMIT_PCT=0.02
RISK_MAX_ORDERS_PER_MINUTE=60
RISK_MAX_VAR_95_PCT=0.05
RISK_IDX_LOT_SIZE=100

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=pyhron-strategies

# Monitoring
SENTRY_DSN=
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090

# Data Ingestion
EODHD_API_TOKEN=your_eodhd_token_here
YFINANCE_FALLBACK_ENABLED=true
CCXT_EXCHANGE=binance
KAFKA_RAW_TOPIC_PARTITIONS=3
TIMESCALEDB_WRITER_BATCH_SIZE=1000
DATA_QUALITY_COVERAGE_THRESHOLD=0.95

# Notifications
SLACK_WEBHOOK_URL=
ALERT_EMAIL=
