# =============================================================================
# Enthropy - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -- Market Data & Brokerage -------------------------------------------------

# Polygon.io / Massive API key for market data
MASSIVE_API_KEY=your_polygon_api_key_here

# Alpaca trading API
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# CCXT crypto exchange (e.g., binance, coinbase, kraken)
CCXT_EXCHANGE=binance

# IDX API key
IDX_API_KEY=your_idx_api_key_here

# -- Database & Cache --------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://enthropy:enthropy@localhost:5432/enthropy

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# -- Authentication & Security -----------------------------------------------

# Application secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=change-me-to-a-random-secret

# JWT signing secret
JWT_SECRET=change-me-to-a-jwt-secret

# Encryption key for sensitive data at rest (Fernet key, 32 url-safe base64 bytes)
ENCRYPTION_KEY=change-me-to-a-fernet-key

# -- ML & Experiment Tracking ------------------------------------------------

# MLflow tracking server URI
MLFLOW_TRACKING_URI=http://localhost:5000

# -- Event Streaming ---------------------------------------------------------

# Kafka bootstrap servers (comma-separated)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
