{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": "Prometheus",
        "enable": true,
        "expr": "ALERTS{alertstate=\"firing\"}",
        "iconColor": "red",
        "name": "Firing Alerts",
        "tagKeys": "alertname",
        "type": "tags"
      }
    ]
  },
  "description": "Enthropy Quantitative Trading Platform - Operations Dashboard",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "System Health Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "API Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "unit": "percentunit",
          "decimals": 3
        }
      },
      "targets": [
        {
          "expr": "avg_over_time(up{job=\"enthropy-api\"}[24h])",
          "legendFormat": "Uptime"
        }
      ]
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 900 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(http_connections_active{job=\"enthropy-api\"})",
          "legendFormat": "Connections"
        }
      ]
    },
    {
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"enthropy-api\"}[5m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"enthropy-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"enthropy-api\"}[5m]))",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg(rate(process_cpu_seconds_total{job=\"enthropy-api\"}[5m]))",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 1610612736 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"enthropy-api\"}",
          "legendFormat": "RSS"
        }
      ]
    },
    {
      "title": "Order Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Order Latency Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "bucketOffset": 0,
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "scheme",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(order_latency_seconds_bucket{job=\"enthropy-quant-metrics\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(order_latency_seconds_bucket{job=\"enthropy-quant-metrics\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(order_latency_seconds_bucket{job=\"enthropy-quant-metrics\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Order Latency Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(order_latency_seconds_bucket{job=\"enthropy-quant-metrics\"}[5m])) by (le))",
          "legendFormat": "p50 Latency"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(order_latency_seconds_bucket{job=\"enthropy-quant-metrics\"}[5m])) by (le))",
          "legendFormat": "p95 Latency"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(order_latency_seconds_bucket{job=\"enthropy-quant-metrics\"}[5m])) by (le))",
          "legendFormat": "p99 Latency"
        }
      ]
    },
    {
      "title": "PnL & Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Daily PnL",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "pnl_daily_total{job=\"enthropy-quant-metrics\"}",
          "legendFormat": "{{ strategy }}"
        }
      ]
    },
    {
      "title": "Cumulative PnL",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "lineWidth": 2,
            "gradientMode": "scheme"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(pnl_daily_total{job=\"enthropy-quant-metrics\"}[30d])) by (strategy)",
          "legendFormat": "{{ strategy }} Cumulative"
        }
      ]
    },
    {
      "title": "Risk Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Value at Risk (VaR)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1000000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "risk_var_current{job=\"enthropy-quant-metrics\"}",
          "legendFormat": "Current VaR"
        },
        {
          "expr": "risk_var_limit{job=\"enthropy-quant-metrics\"}",
          "legendFormat": "VaR Limit"
        }
      ]
    },
    {
      "title": "Position Exposure",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": { "mode": "normal" }
          }
        }
      },
      "targets": [
        {
          "expr": "position_exposure_total{job=\"enthropy-quant-metrics\"}",
          "legendFormat": "{{ asset_class }} Exposure"
        }
      ]
    },
    {
      "title": "Drawdown %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 30,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "drawdown_current_pct{job=\"enthropy-quant-metrics\"}",
          "legendFormat": "{{ strategy }} Drawdown"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["enthropy", "trading", "quantitative"],
  "templating": {
    "list": [
      {
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "label": "Data Source",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "datasource": "Prometheus",
        "definition": "label_values(pnl_daily_total, strategy)",
        "hide": 0,
        "includeAll": true,
        "label": "Strategy",
        "multi": true,
        "name": "strategy",
        "query": "label_values(pnl_daily_total, strategy)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "timezone": "browser",
  "title": "Enthropy Trading Platform",
  "uid": "enthropy-main",
  "version": 1
}
